{
  "name": "copilot-mission-control",
  "version": "0.2.13",
  "description": "Agent Mission Control — a live dashboard for the GitHub Copilot CLI",
  "scripts": {
    "build:frontend": "node scripts/build-frontend.ts",
    "build:docs": "node scripts/build-docs.ts",
    "build": "npm run build:frontend && cd src-tauri && cargo build",
    "tauri": "tauri",
    "start": "npm run build:frontend && cd src-tauri && cargo tauri dev",
    "dev": "cargo tauri dev",
    "dist": "cargo tauri build",
    "dist:mac": "cargo tauri build --target universal-apple-darwin",
    "dist:win": "cargo tauri build --target x86_64-pc-windows-msvc",
    "dist:linux": "cargo tauri build --target x86_64-unknown-linux-gnu",
    "test": "npm run build:frontend && npx playwright test",
    "test:headed": "npm run build:frontend && npx playwright test --headed",
    "test:mcp": "node --test tests/mcp-insights.test.mts",
    "test:skill-evaluator": "cd src-tauri && cargo test skill_evaluator --quiet",
    "test:skill-evaluator:copilot-sdk": "cd src-tauri && CMC_RUN_COPILOT_SDK_TESTS=1 cargo test copilot_sdk_judge_integration_returns_result -- --ignored",
    "mcp:insights": "node mcp/mission-control-insights.ts",
    "release": "node scripts/release.ts",
    "test:updater": "node scripts/test-updater.ts"
  },
  "author": "Dan Wahlin",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.0.0",
    "serve": "^14.2.6",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "phaser": "^4.0.0"
  }
}
